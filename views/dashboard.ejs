<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">

    <%- include('partials/sidebar') %>

    <div class="main-content">
        <%- include('partials/topbar') %>

        <div class="page-body">

            <div class="page-header">
                <div>
                    <h1>Dashboard</h1>
                    <p>Welcome to BOARDLINK — Integrated Digital Archiving and Board Governance Platform</p>
                </div>
                <a href="/archive/upload" class="btn btn-gold">➕ Upload Document</a>
            </div>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon blue">🗂️</div>
                    <div class="stat-info">
                        <div class="stat-value"><%= stats.totalDocuments.toLocaleString() %></div>
                        <div class="stat-label">Total Documents</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon gold">📋</div>
                    <div class="stat-info">
                        <div class="stat-value"><%= stats.pendingAgendas %></div>
                        <div class="stat-label">Pending Agendas</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green">📅</div>
                    <div class="stat-info">
                        <div class="stat-value"><%= stats.upcomingMeetings %></div>
                        <div class="stat-label">Upcoming Meetings</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon purple">👥</div>
                    <div class="stat-info">
                        <div class="stat-value"><%= stats.totalUsers %></div>
                        <div class="stat-label">Active Users</div>
                    </div>
                </div>
            </div>

            <!-- Quick Access Cards -->
            <div class="grid-3 mb-20">
                <a href="/ocr/search" class="card" style="padding:20px; display:block; text-align:center; transition:transform 0.2s; cursor:pointer;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                    <div style="font-size:32px; margin-bottom:10px;">🔍</div>
                    <div style="font-weight:700; color:var(--navy); font-size:14px;">AI-Powered Search</div>
                    <div class="text-muted">Search archived documents</div>
                </a>
                <a href="/meeting/transcription" class="card" style="padding:20px; display:block; text-align:center; transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                    <div style="font-size:32px; margin-bottom:10px;">🎙️</div>
                    <div style="font-weight:700; color:var(--navy); font-size:14px;">AI Transcription</div>
                    <div class="text-muted">Transcribe meeting audio</div>
                </a>
                <a href="/meeting/summary" class="card" style="padding:20px; display:block; text-align:center; transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
                    <div style="font-size:32px; margin-bottom:10px;">📄</div>
                    <div style="font-weight:700; color:var(--navy); font-size:14px;">AI Summary</div>
                    <div class="text-muted">Generate meeting summaries</div>
                </a>
            </div>

            <!-- Recent Documents Table -->
            <div class="card">
                <div class="card-header">
                    <h2>📁 Recent Documents</h2>
                    <a href="/archive" class="btn btn-secondary btn-sm">View All</a>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% documents.forEach((doc, index) => { %>
                            <tr>
                                <td class="text-muted"><%= index + 1 %></td>
                                <td class="fw-700"><%= doc.title %></td>
                                <td><%= doc.type %></td>
                                <td class="text-muted"><%= doc.date %></td>
                                <td>
                                    <span class="badge badge-<%= doc.status.toLowerCase() %>">
                                        <%= doc.status %>
                                    </span>
                                </td>
                                <td>
                                    <a href="/archive/<%= doc.id %>" class="btn btn-secondary btn-sm">View</a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /page-body -->
    </div><!-- /main-content -->
</div><!-- /app-layout -->
</body>
</html>
