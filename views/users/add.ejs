<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/topbar') %>
        <div class="page-body">
            <div class="page-header">
                <div><h1>➕ Add New User</h1><p><a href="/users" style="color:var(--gold);">← Back to Users</a></p></div>
            </div>
            <div class="card" style="max-width:580px;">
                <div class="card-header"><h2>👤 User Account Details</h2></div>
                <div class="card-body">
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-error">⚠️ <%= error %></div>
                    <% } %>
                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="alert alert-success">✅ <%= success %></div>
                    <% } %>
                    <form action="/users/add" method="POST">
                        <div class="form-group">
                            <label>Full Name *</label>
                            <input type="text" name="fullName" placeholder="e.g. Dr. Maria Reyes" required>
                        </div>
                        <div class="form-group">
                            <label>Username *</label>
                            <input type="text" name="username" placeholder="e.g. mreyes" required>
                        </div>
                        <div class="form-group">
                            <label>Email Address *</label>
                            <input type="email" name="email" placeholder="e.g. mreyes@cspc.edu.ph" required>
                        </div>
                        <div class="form-group">
                            <label>Assign Role *</label>
                            <select name="role" required>
                                <option value="">— Select Role —</option>
                                <% roles.forEach(role => { %>
                                    <option value="<%= role %>"><%= role %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="flex gap-10 mt-16">
                            <button type="submit" class="btn btn-primary">➕ Add User to BOARDLINK</button>
                            <a href="/users" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
