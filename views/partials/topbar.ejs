<!-- views/partials/topbar.ejs -->
<header class="topbar">
    <div class="topbar-title"><%= title.split('|')[0].trim() %></div>
    <div class="topbar-actions">
        <div class="topbar-user">
            <div class="avatar">BS</div>
            <div class="user-info">
                <span class="user-name">Board Secretary</span>
                <span class="user-role">Administrator</span>
            </div>
        </div>
        <a href="/" class="btn btn-secondary btn-sm">🔒 Logout</a>
    </div>
</header>
