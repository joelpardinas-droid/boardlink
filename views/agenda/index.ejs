<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/topbar') %>
        <div class="page-body">

            <div class="page-header">
                <div>
                    <h1>📋 Agenda Management</h1>
                    <p>Manage and distribute board meeting agendas at least 5 days before scheduled meetings</p>
                </div>
                <a href="/agenda/create" class="btn btn-gold">➕ Create Agenda</a>
            </div>

            <% if (agendas.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <h3>No Agendas Found</h3>
                    <p>Create the first meeting agenda to get started.</p>
                </div>
            <% } else { %>
                <div style="display:flex; flex-direction:column; gap:16px;">
                    <% agendas.forEach(agenda => { %>
                    <div class="card">
                        <div class="card-body">
                            <div class="flex-between">
                                <div>
                                    <div style="font-size:17px; font-weight:700; color:var(--navy); margin-bottom:6px;">
                                        📅 <%= agenda.title %>
                                    </div>
                                    <div class="text-muted">
                                        📆 <%= agenda.date %> &nbsp;|&nbsp; 🕐 <%= agenda.time %> &nbsp;|&nbsp; 📍 <%= agenda.location %>
                                    </div>
                                    <div class="mt-16" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                                        <span class="badge badge-<%= agenda.status.toLowerCase() %>"><%= agenda.status %></span>
                                        <span class="text-muted">📅 <%= agenda.daysLeft %> days remaining</span>
                                        <span class="text-muted">📝 <%= agenda.items.length %> agenda items</span>
                                        <span class="text-muted">💬 <%= agenda.comments.length %> comment(s)</span>
                                    </div>
                                </div>
                                <div class="flex gap-10">
                                    <a href="/agenda/<%= agenda.id %>" class="btn btn-primary btn-sm">👁 View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            <% } %>

        </div>
    </div>
</div>
</body>
</html>
